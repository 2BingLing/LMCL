      position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
      text-align: center; color: white; font-weight: 900; letter-spacing: 6px;
      text-shadow: 0 0 20px rgba(255,215,0,0.9), 0 0 40px rgba(255,100,0,0.7);
      font-family: &#39;Microsoft YaHei&#39;, sans-serif; line-height: 1.1;
      font-size: clamp(40px, 10vw, 80px);
      z-index: 20;
    &#34;&gt;新年联动派对&lt;/div&gt;
  `;
  overlay.appendChild(title);
  const canvas = document.createElement(&#39;canvas&#39;);
  canvas.style.cssText = `
    position: absolute; top: 0; left: 0; width: 100%; height: 100%;
    z-index: 5;
  `;
  overlay.appendChild(canvas);
  const ctx = canvas.getContext(&#39;2d&#39;);
  let w = window.innerWidth, h = window.innerHeight;
  canvas.width = w; canvas.height = h;
  const resize = () =&gt; {
    w = canvas.width = window.innerWidth;
    h = canvas.height = window.innerHeight;
  };
  window.addEventListener(&#39;resize&#39;, resize);
  const colors = [&#39;#ff0000&#39;, &#39;#ffff00&#39;, &#39;#00ff00&#39;, &#39;#ff00ff&#39;, &#39;#ffffff&#39;];
  let particles = [];
  class Particle {
    constructor(x, y) {
      this.x = x; this.y = y;
      this.color = colors[Math.floor(Math.random() * colors.length)];
      this.radius = Math.random() * 2 + 0.8;
      this.vx = (Math.random() - 0.5) * 6;
      this.vy = (Math.random() - 0.5) * 6;
      this.alpha = 1;
      this.decay = Math.random() * 0.02 + 0.01;
    }
    draw() {
      ctx.save();
      ctx.globalAlpha = this.alpha;
      ctx.beginPath();
      ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
      ctx.fillStyle = this.color;
      ctx.fill();
      ctx.restore();
    }
    update() {
      this.x += this.vx;
      this.y += this.vy;
      this.alpha -= this.decay;
      this.draw();
      return this.alpha &gt; 0;
    }
  }
  function launchFirework() {
    if (Math.random() &lt; 0.02) {
      const x = Math.random() * w;
      const y = Math.random() * h * 0.5;
      const n = 100 + Math.random() * 80;
      for (let i = 0; i &lt; n; i++) particles.push(new Particle(x, y));
    }
  }
  function animate() {
    if (!window._nyPartyActive) return;
    requestAnimationFrame(animate);
    ctx.fillStyle = &#39;rgba(0,0,0,0.08)&#39;;
    ctx.fillRect(0, 0, w, h);
    launchFirework();
    particles = particles.filter(p =&gt; p.update());
  }
  animate();
  const audio = new Audio(NY_MUSIC_PATH);
  audio.volume = 0.6;
  audio.loop = true;
  audio.play().catch(() =&gt; {
  });
  function closeParty() {
    if (!window._nyPartyActive) return;
    window._nyPartyActive = false;
    if (overlay.parentNode) overlay.parentNode.removeChild(overlay);
    if (!audio.paused) audio.pause();
    audio.src = &#39;&#39;;
    document.removeEventListener(&#39;click&#39;, closeParty);
    document.removeEventListener(&#39;touchstart&#39;, closeParty);
  }
  document.addEventListener(&#39;click&#39;, closeParty);
  document.addEventListener(&#39;touchstart&#39;, closeParty, { passive: true });
})();
&lt;/script&gt;
</description>
