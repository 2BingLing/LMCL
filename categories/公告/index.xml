le=&#34;       flex: 1;       min-width: 200px;       display: flex;       flex-direction: column;       justify-content: center;       gap: 24px;     &#34;&gt;       &lt;!-- 轻音会社 --&gt;       &lt;div style=&#34;text-align: center;&#34;&gt;         &lt;img src=&#34;blue.png&#34; 
