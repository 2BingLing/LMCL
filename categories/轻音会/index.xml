  &lt;div style=&#34;text-align: right; margin-top: 8px;&#34;&gt;
    &lt;button onclick=&#34;document.getElementById(&#39;audio-panel&#39;).style.display=&#39;none&#39;;&#34; style=&#34;font-size: 12px; color: #6b8fd9; background: none; border: none; cursor: pointer;&#34;&gt;收起&lt;/button&gt;
  &lt;/div&gt;
&lt;/div&gt;
&lt;script&gt;
(function() {
  const audio = document.getElementById(&#39;audio-player&#39;);
  const floatBtn = document.getElementById(&#39;audio-float&#39;);
  let hasPlayed = false;
  const quote = document.querySelector(&#39;.award-quote&#39;);
  if (quote) {
    const text = quote.textContent || &#39;&#39;;
    quote.textContent = &#39;&#39;;
    let i = 0;
    const timer = setInterval(() =&gt; {
      if (i &lt; text.length) {
        quote.innerHTML += text.charAt(i);
        i++;
      } else {
        clearInterval(timer);
        const cursor = document.createElement(&#39;span&#39;);
        cursor.innerHTML = &#39;|&#39;;
        cursor.style.animation = &#39;blink 1s infinite&#39;;
        quote.appendChild(cursor);
        const style = document.createElement(&#39;style&#39;);
        style.textContent = `@keyframes blink { 50% { opacity: 0; } }`;
        document.head.appendChild(style);
      }
    }, 200);
  }
  const observer = new IntersectionObserver(entries =&gt; {
    entries.forEach(entry =&gt; {
      if (entry.isIntersecting) entry.target.classList.add(&#39;fade-in&#39;);
    });
  }, { threshold: 0.1 });
  document.querySelectorAll(&#39;.fade-card&#39;).forEach(el =&gt; {
    el.classList.add(&#39;fade-out&#39;);
    observer.observe(el);
  });
  function updateButton() {
    floatBtn.textContent = audio.paused ? &#39;▶&#39; : &#39;⏸&#39;;
  }
  function tryAutoPlay() {
    if (!hasPlayed) {
      audio.muted = true;
      audio.play().then(() =&gt; {
        setTimeout(() =&gt; {
          audio.muted = false;
          hasPlayed = true;
          updateButton();
        }, 100);
      }).catch(e =&gt; console.log(&#34;播放失败&#34;, e));
    }
  }
  [&#39;click&#39;, &#39;touchstart&#39;, &#39;keydown&#39;, &#39;scroll&#39;].forEach(event =&gt; {
    document.addEventListener(event, tryAutoPlay, { once: true, passive: true });
  });
  floatBtn.addEventListener(&#39;click&#39;, () =&gt; {
    if (!hasPlayed) {
      tryAutoPlay();
      return;
    }
    if (audio.paused) {
      audio.play().then(updateButton);
    } else {
      audio.pause();
      updateButton();
    }
  });
  audio.addEventListener(&#39;play&#39;, updateButton);
  audio.addEventListener(&#39;pause&#39;, updateButton);
  audio.addEventListener(&#39;ended&#39;, () =&gt; {
    floatBtn.textContent = &#39;▶&#39;;
  });
  const style = document.createElement(&#39;style&#39;);
  style.textContent = `
    .fade-out { opacity: 0; transform: translateY(20px); transition: all 0.6s ease; }
    .fade-in { opacity: 1; transform: translateY(0); }
    .custom-card:hover {
      transform: translateY(-5px) !important;
      box-shadow: 0 15px 35px rgba(0,0,0,0.12) !important;
    }
    #audio-float:hover { transform: scale(1.1); }
    @keyframes blink { 50% { opacity: 0; } }
  `;
  document.head.appendChild(style);
})();
&lt;/script&gt;
