    &lt;/style&gt;
    &lt;input type=&#34;range&#34; id=&#34;volume-control&#34; min=&#34;0&#34; max=&#34;1&#34; step=&#34;0.1&#34; value=&#34;0.7&#34; style=&#34;
        width: 50px;
