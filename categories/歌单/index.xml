&lt;/div&gt;
&lt;script&gt;
document.addEventListener(&#39;DOMContentLoaded&#39;, function() {
    const audio = document.getElementById(&#39;audio-source&#39;);
    const playBtn = document.getElementById(&#39;play-btn&#39;);
    const player = document.getElementById(&#39;music-player&#39;);
    const progressBar = document.getElementById(&#39;progress-bar&#39;);
    const volumeControl = document.getElementById(&#39;volume-control&#39;);
    const songTitle = document.getElementById(&#39;song-title&#39;);
    const songArtist = document.getElementById(&#39;song-artist&#39;);
    document.querySelectorAll(&#39;.play-trigger&#39;).forEach(button =&gt; {
        button.addEventListener(&#39;click&#39;, function(e) {
            e.stopPropagation();
            const item = this.closest(&#39;.ranking-item&#39;);
            const src = item.getAttribute(&#39;data-src&#39;); 
            const title = item.getAttribute(&#39;data-title&#39;);
            const artist = item.getAttribute(&#39;data-artist&#39;);
            audio.src = src; 
            songTitle.textContent = title;
            songArtist.textContent = artist;
            audio.play().then(() =&gt; {
                playBtn.textContent = &#39;❚❚&#39;;
                player.style.transform = &#39;translateY(-10px)&#39;;
            }).catch(err =&gt; {
                alert(&#34;播放失败，请检查外链地址或网络&#34;);
                console.error(&#34;播放被阻止:&#34;, err);
            });
        });
    });
    playBtn.addEventListener(&#39;click&#39;, function() {
        if (audio.src &amp;&amp; audio.duration &gt; 0) {
            if (audio.paused) {
                audio.play();
                playBtn.textContent = &#39;❚❚&#39;;
            } else {
                audio.pause();
                playBtn.textContent = &#39;▶&#39;;
            }
        }
    });
    volumeControl.addEventListener(&#39;input&#39;, function() {
        audio.volume = this.value;
    });
    audio.ontimeupdate = function() {
        const value = (audio.currentTime / audio.duration) * 100;
        if (!isNaN(value)) {
            progressBar.value = value;
        }
    };
    progressBar.addEventListener(&#39;input&#39;, function() {
        const seekTime = audio.duration * (this.value / 100);
        if (!isNaN(seekTime)) {
            audio.currentTime = seekTime;
        }
    });
    audio.addEventListener(&#39;ended&#39;, function() {
        playBtn.textContent = &#39;▶&#39;;
        player.style.transform = &#39;translateY(0)&#39;;
        progressBar.value = 0;
    });
});
&lt;/script&gt;
