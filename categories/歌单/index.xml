&lt;script&gt;
document.addEventListener(&#39;DOMContentLoaded&#39;, function() {
    function updateRankNumbers() {
        const list = document.querySelector(&#39;.ranking-list&#39;);
        const items = list ? list.querySelectorAll(&#39;.ranking-item&#39;) : [];
        items.forEach((item, index) =&gt; {
            const numberDiv = item.querySelector(&#39;div[style*=&#34;counter-increment&#34;]&#39;) || 
                             item.querySelector(&#39;div[style*=&#34;width: 60px&#34;]&#39;); // 容错选择器
            if (numberDiv) {
                const span = numberDiv.querySelector(&#39;span span&#39;);
                if (span) {
                    span.innerHTML = &#39;&lt;span style=&#34;font-family: sans-serif;&#34;&gt;#&lt;/span&gt;&#39; + (index + 1);
                }
            }
        });
    }
    updateRankNumbers();
    const list = document.querySelector(&#39;.ranking-list&#39;);
    if (list) {
        const observer = new MutationObserver(updateRankNumbers);
        observer.observe(list, { childList: true });
    }
    document.querySelectorAll(&#39;.play-trigger&#39;).forEach(button =&gt; {
        button.addEventListener(&#39;click&#39;, function(e) {
            e.stopPropagation();
            const item = this.closest(&#39;.ranking-item&#39;);
            const src = item.getAttribute(&#39;data-src&#39;);
            const title = item.getAttribute(&#39;data-title&#39;);
            const artist = item.getAttribute(&#39;data-artist&#39;);
            window.dispatchEvent(new CustomEvent(&#39;playSong&#39;, {
                detail: { src, title, artist }
            }));
        });
    });
});
&lt;/script&gt;
